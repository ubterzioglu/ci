{
  "name": "cineocucina",
  "version": "1.0.0",
  "private": true,
  "description": "Çi Neo Cucina — modern restaurant website (Next.js + Supabase)",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@10.28.1",
  "pnpm": {
    "onlyBuiltDependencies": ["sharp", "esbuild", "unrs-resolver"]
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "db:types": "supabase gen types typescript --local > src/lib/supabase/database.types.ts",
    "db:seed": "tsx scripts/seed-supabase.ts",
    "db:reset": "supabase db reset",
    "assets:download": "tsx scripts/download-assets.ts",
    "i18n:translate": "tsx scripts/translate-content.ts"
  },
  "dependencies": {
    "@supabase/ssr": "0.12.0",
    "@supabase/supabase-js": "2.108.2",
    "next": "16.2.9",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "server-only": "0.0.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.1",
    "@types/node": "24.10.1",
    "@types/react": "19.2.3",
    "@types/react-dom": "19.2.3",
    "dotenv": "17.4.2",
    "eslint": "9.39.0",
    "eslint-config-next": "16.2.9",
    "eslint-config-prettier": "10.1.8",
    "prettier": "3.7.0",
    "prettier-plugin-tailwindcss": "0.8.0",
    "tailwindcss": "4.3.1",
    "tsx": "4.22.4",
    "typescript": "5.9.3"
  }
}
