
# ---------------------------------------------------------------------------
# Çi Neo Cucina — .gitignore
# ---------------------------------------------------------------------------

# Environment & secrets (NEVER commit) ---------------------------------------
.env
.env.*
!.env.example
.env.local
.env.development.local
.env.test.local
.env.production.local

# Dependencies ---------------------------------------------------------------
node_modules/
.pnpm-store/
.pnp.*

# Next.js build output -------------------------------------------------------
.next/
out/
build/
dist/
next-env.d.ts

# Vercel / Coolify -----------------------------------------------------------
.vercel/

# TypeScript -----------------------------------------------------------------
*.tsbuildinfo

# Supabase local stack -------------------------------------------------------
supabase/.branches/
supabase/.temp/
**/.supabase/

# Testing / coverage ---------------------------------------------------------
coverage/
.nyc_output/

# Downloaded / imported binary assets (regenerated via scripts) --------------
# NOTE: imported restaurant images are committed; keep this commented unless
# the team decides to fetch assets at build time instead.
# public/images/imported/

# Raw Wix export (NEVER commit) ----------------------------------------------
# Contains customer/order/member data (Members/*, Stores/Orders) and large raw
# images. Curated content lives in src/content/; gallery images are optimised
# into public/images/gallery/ via scripts/optimize-gallery.ts.
wix/
wix-export/

# Logs -----------------------------------------------------------------------
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# OMC (oh-my-claudecode) local tooling state ---------------------------------
.omc/

# Large raw media (host on CDN/storage, not in git) -------------------------
# Hero/marketing source videos are hundreds of MB and exceed GitHub's 100 MB
# limit. The hero uses an optimised image, not a video — keep these local only.
*.mov
*.MOV
*.mp4

# OS / editor cruft ----------------------------------------------------------
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
