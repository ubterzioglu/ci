# ---------------------------------------------------------------------------
# Çi Neo Cucina — environment variable template
# Copy to `.env.local` and fill in real values. NEVER commit `.env.local`.
# ---------------------------------------------------------------------------

# Public site URL (canonical URLs, sitemap, Open Graph). No trailing slash.
NEXT_PUBLIC_SITE_URL=https://www.cineocucina.com

# --- Supabase ---------------------------------------------------------------
# Project URL, e.g. https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
# anon / publishable key — safe for the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# service_role key — SERVER ONLY, never sent to the browser
SUPABASE_SERVICE_ROLE_KEY=

# Optional: new-style secret API key (server only) and CLI access token
SUPABASE_SECRET_KEY=
SUPABASE_ACCESS_TOKEN=
# Direct Postgres connection string (used by the seed script)
SUPABASE_DB_URL=

# --- Translation (DeepL) — OPTIONAL ----------------------------------------
# Used by `pnpm i18n:translate` to generate EN/DE content from Turkish source.
DEEPL_API_KEY=

# --- Email notifications (Resend) — OPTIONAL --------------------------------
# If RESEND_API_KEY is empty, the app skips email and only stores submissions.
RESEND_API_KEY=
RESERVATION_NOTIFICATION_EMAIL=cineo.cucina@gmail.com
CONTACT_NOTIFICATION_EMAIL=cineo.cucina@gmail.com
