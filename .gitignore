# ---------------------------------------------------------------------------
# Çi Neo Cucina — .gitignore
# ---------------------------------------------------------------------------

# Environment & secrets (NEVER commit) ---------------------------------------
.env
.env.*
!.env.example
.env.local
.env.development.local
.env.test.local
.env.production.local

# Dependencies ---------------------------------------------------------------
node_modules/
.pnpm-store/
.pnp.*

# Next.js build output -------------------------------------------------------
.next/
out/
build/
dist/
next-env.d.ts

# Vercel / Coolify -----------------------------------------------------------
.vercel/

# TypeScript -----------------------------------------------------------------
*.tsbuildinfo

# Supabase local stack -------------------------------------------------------
supabase/.branches/
supabase/.temp/
**/.supabase/

# Testing / coverage ---------------------------------------------------------
coverage/
.nyc_output/

# Downloaded / imported binary assets (regenerated via scripts) --------------
# NOTE: imported restaurant images are committed; keep this commented unless
# the team decides to fetch assets at build time instead.
# public/images/imported/

# Logs -----------------------------------------------------------------------
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# OMC (oh-my-claudecode) local tooling state ---------------------------------
.omc/

# OS / editor cruft ----------------------------------------------------------
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
